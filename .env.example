# ─────────────────────────────────────────────
# LeadPulse Environment Configuration
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# App
APP_NAME="LeadPulse"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."  # From Clerk Dashboard > Webhooks

# Clerk Redirect URLs (no need to change these)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Reddit API
REDDIT_CLIENT_ID="your-reddit-client-id"
REDDIT_CLIENT_SECRET="your-reddit-client-secret"
REDDIT_USER_AGENT="LeadPulse/1.0 by YourUsername"

# Twitter / X API v2
TWITTER_API_KEY="your-api-key"
TWITTER_API_SECRET="your-api-secret"
TWITTER_BEARER_TOKEN="your-bearer-token"

# OpenAI
OPENAI_API_KEY="sk-..."

# Email (Resend)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="alerts@leadpulse.io"

# Payments (PayU)
NEXT_PUBLIC_PAYU_MODE=test
PAYU_MERCHANT_KEY_TEST="your-test-merchant-key"
PAYU_MERCHANT_SALT_TEST="your-test-merchant-salt"
PAYU_MERCHANT_KEY_LIVE="your-live-merchant-key"
PAYU_MERCHANT_SALT_LIVE="your-live-merchant-salt"

# Security
CRON_SECRET="your-cron-secret-token"
